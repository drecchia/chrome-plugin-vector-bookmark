	},
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.6.1",
		"axios": "^1.7.9",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2"
	}
}
