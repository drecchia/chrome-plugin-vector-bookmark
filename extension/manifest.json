{
	"manifest_version": 3,
	"name": "Vector Bookmark",
	"version": "0.1.0",
	"description": "Semantic recall for everything you've read.",
	"incognito": "not_allowed",
	"permissions": [
		"nativeMessaging",
		"tabs",
		"webNavigation",
		"storage",
		"omnibox",
		"idle"
	],
	"host_permissions": ["<all_urls>"],
	"background": {
		"service_worker": "src/background/service-worker.ts",
		"type": "module"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["src/content/extract.ts"],
			"run_at": "document_idle"
		}
	],
	"action": {
		"default_popup": "src/popup/index.html",
		"default_icon": {
			"16": "icons/icon16.png",
			"48": "icons/icon48.png",
			"128": "icons/icon128.png"
		}
	},
	"omnibox": {
		"keyword": "@recall"
	},
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	}
}
