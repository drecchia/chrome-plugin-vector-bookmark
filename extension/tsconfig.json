{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022", "DOM"],
		"strict": true,
		"jsx": "react-jsx",
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"noEmit": true
	},
	"include": ["src/**/*", "manifest.json", "../proto/**/*"]
}
