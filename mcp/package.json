{
	"name": "vector-bookmark-mcp-server",
	"version": "1.0.0",
	"description": "Read-only MCP server exposing the Vector Bookmark daemon (vbmd) browsing-memory API as tools",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"vector-bookmark-mcp-server": "dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"start": "node dist/index.js",
		"dev": "tsx watch src/index.ts",
