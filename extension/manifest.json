{
	"manifest_version": 3,
	"name": "Vector Bookmark",
	"version": "1.1.2",
	"description": "Semantic recall for everything you've read. 100% local hybrid BM25 + vector search across your browsing history.",
	"homepage_url": "https://github.com/drecchia/chrome-plugin-vector-bookmark",
	"minimum_chrome_version": "116",
	"incognito": "not_allowed",
	"content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'self'"
	},
	"permissions": [
		"tabs",
		"webNavigation",
		"storage",
		"omnibox",
		"idle",
		"scripting"
	],
	"host_permissions": ["<all_urls>"],
	"background": {
		"service_worker": "src/background/service-worker.ts",
		"type": "module"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["src/content/extract.ts"],
			"run_at": "document_idle"
		}
	],
	"action": {
		"default_popup": "src/popup/index.html",
		"default_icon": {
			"16": "icons/icon16.png",
			"48": "icons/icon48.png",
			"128": "icons/icon128.png"
		}
	},
	"omnibox": {
		"keyword": "@recall"
	},
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	}
}
